# Copy this file to ".env" and fill in your values for local dev.
# In production, set these in the Netlify dashboard (Site settings -> Environment).

# Stripe SECRET key. Start in TEST mode: it looks like "sk_test_...".
# Get it at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Secret used to sign login + wallet tokens (HMAC). Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If you change this later, existing sessions become invalid (balances are kept
# by account id; users just have to log in again).
TOKEN_SECRET=change-me-to-a-long-random-string

# Tripo3D text-to-3D API key (https://platform.tripo3d.ai). Starts with "tsk_".
# Kept server-side and injected by the /api/tripo proxy, so it never ships to
# the browser. Optional — without it, AI mode falls back to the free engine.
TRIPO_API_KEY=tsk_your_api_key_here
